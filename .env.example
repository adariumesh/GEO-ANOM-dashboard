# =============================================================================
# GEO-ANOM Environment Variables — copy to .env and fill in values
# =============================================================================

# --- Google Cloud (required for GCS + Vertex AI) ---
# Path to service account JSON key (recommended)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# Or set project/bucket directly:
GCS_BUCKET=geo-anom-maryland
GCS_PROJECT_ID=your-gcp-project-id

# --- Google Earth Engine (for AlphaEarth filtering) ---
# Option A: Service account (same key as above usually works)
EE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
EE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
# Option B: Interactive auth — run `earthengine authenticate` (leave above blank)

# --- Optional Overrides ---
DATA_DIR=./data
LOG_LEVEL=INFO
